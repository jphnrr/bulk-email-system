# ============================================
# BREVO SMTP CONFIGURATION
# ============================================
# Get these from: https://app.brevo.com/settings/keys/smtp
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_USER=your_brevo_login_email@example.com
BREVO_SMTP_PASS=your_brevo_smtp_key_here

# ============================================
# SENDER DETAILS
# ============================================
FROM_NAME=Your Company Name
FROM_EMAIL=noreply@yourdomain.com
REPLY_TO=support@yourdomain.com

# ============================================
# CAMPAIGN SETTINGS
# ============================================
# How many emails to send per batch (keep low to avoid spam filters)
BATCH_SIZE=50

# Delay between each email in milliseconds (1000 = 1 second)
EMAIL_DELAY_MS=1000

# Delay between batches in milliseconds (60000 = 1 minute)
BATCH_DELAY_MS=60000

# How many times to retry a failed email
MAX_RETRIES=3

# ============================================
# SCHEDULER (cron format)
# ============================================
# Default: Run every day at 9:00 AM
# Format: second minute hour day month weekday
CRON_SCHEDULE=0 9 * * *

# ============================================
# ACTIVE CAMPAIGN
# ============================================
# Filename inside /campaigns folder (without .json)
ACTIVE_CAMPAIGN=welcome-campaign
